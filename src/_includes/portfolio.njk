<!DOCTYPE html>
<html lang="{{ htmlLang or 'en' }}">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{ title }}</title>
  <meta name="description" content="{{ description }}" />
  <meta name="robots" content="noindex" />
  {{ headExtra | safe if headExtra }}
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@500;600&display=swap">
  <style>
    /* overflow:hidden no body quebra position:fixed — clip preserva o comportamento sem criar scroll container */
    html, body { overflow-x: clip !important; }

    .portfolio-badge {
      position: fixed;
      bottom: 24px;
      right: 24px;
      z-index: 9999;
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 10px 18px;
      background: rgba(10, 10, 11, 0.92);
      border: 1px solid rgba(57, 255, 135, 0.25);
      border-radius: 100px;
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      box-shadow: 0 4px 24px rgba(0, 0, 0, 0.4), 0 0 0 1px rgba(57, 255, 135, 0.06);
      font-family: 'Inter', system-ui, sans-serif;
      font-size: 0.78rem;
      font-weight: 600;
      color: #FAFAFA;
      text-decoration: none;
      letter-spacing: 0.01em;
      transition: border-color 0.2s, box-shadow 0.2s, transform 0.15s;
      white-space: nowrap;
    }
    .portfolio-badge:hover {
      border-color: rgba(57, 255, 135, 0.5);
      box-shadow: 0 4px 32px rgba(57, 255, 135, 0.12), 0 0 0 1px rgba(57, 255, 135, 0.15);
      transform: translateY(-1px);
    }
    .portfolio-badge-dot {
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background: #39FF87;
      flex-shrink: 0;
      animation: badge-pulse 2s ease-in-out infinite;
    }
    .portfolio-badge-label { color: rgba(250, 250, 250, 0.5); font-weight: 500; }
    .portfolio-badge-name { color: #39FF87; }
    @keyframes badge-pulse {
      0%, 100% { opacity: 1; transform: scale(1); }
      50% { opacity: 0.4; transform: scale(0.7); }
    }
  </style>
</head>
<body>

  {{ content | safe }}

  <a href="https://growthos.com.br" target="_blank" rel="noopener" class="portfolio-badge">
    <span class="portfolio-badge-dot"></span>
    <span class="portfolio-badge-label">Built by</span>
    <span class="portfolio-badge-name">GrowthOS</span>
  </a>

  {{ footerExtra | safe if footerExtra }}
</body>
</html>
