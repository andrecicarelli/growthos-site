<!DOCTYPE html>
<html lang="{{ htmlLang or 'en' }}">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{ title }}</title>
  <meta name="description" content="{{ description }}" />
  <meta name="robots" content="noindex" />
  {{ headExtra | safe if headExtra }}
  <style>
    .portfolio-badge {
      position: fixed;
      bottom: 20px;
      right: 20px;
      z-index: 9999;
      background: rgba(0, 0, 0, 0.75);
      color: #fff;
      border: 1px solid rgba(255, 255, 255, 0.12);
      border-radius: 20px;
      padding: 6px 14px;
      font-size: 0.72rem;
      font-family: system-ui, sans-serif;
      font-weight: 500;
      letter-spacing: 0.02em;
      backdrop-filter: blur(10px);
      -webkit-backdrop-filter: blur(10px);
      text-decoration: none;
      transition: opacity 0.2s;
    }
    .portfolio-badge:hover { opacity: 0.85; }
    .portfolio-badge span { color: #39FF87; }
  </style>
</head>
<body>

  {{ content | safe }}

  <a href="https://growthos.com.br" target="_blank" rel="noopener" class="portfolio-badge">
    Built by <span>GrowthOS</span>
  </a>

  {{ footerExtra | safe if footerExtra }}
</body>
</html>
