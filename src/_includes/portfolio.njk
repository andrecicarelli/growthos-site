<!DOCTYPE html>
<html lang="{{ htmlLang or 'en' }}">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{ title }}</title>
  <meta name="description" content="{{ description }}" />
  <meta name="robots" content="noindex" />
  {{ headExtra | safe if headExtra }}
</head>
<body>

  {{ content | safe }}

  <style>
    html, body { overflow-x: clip !important; }
    .pgbadge {
      position: fixed !important;
      bottom: 24px !important;
      right: 24px !important;
      left: auto !important;
      top: auto !important;
      z-index: 99999 !important;
      display: inline-flex !important;
      align-items: center !important;
      gap: 8px !important;
      padding: 10px 18px !important;
      background: rgba(10, 10, 11, 0.92) !important;
      border: 1px solid rgba(57, 255, 135, 0.25) !important;
      border-radius: 100px !important;
      backdrop-filter: blur(20px) !important;
      -webkit-backdrop-filter: blur(20px) !important;
      box-shadow: 0 4px 24px rgba(0,0,0,0.4), 0 0 0 1px rgba(57,255,135,0.06) !important;
      font-family: 'Inter', system-ui, sans-serif !important;
      font-size: 0.78rem !important;
      font-weight: 600 !important;
      color: #FAFAFA !important;
      text-decoration: none !important;
      letter-spacing: 0.01em !important;
      white-space: nowrap !important;
      transition: border-color 0.2s, box-shadow 0.2s, transform 0.15s !important;
      line-height: 1 !important;
      margin: 0 !important;
      width: auto !important;
      max-width: none !important;
      transform: none !important;
    }
    .pgbadge:hover {
      border-color: rgba(57, 255, 135, 0.5) !important;
      box-shadow: 0 4px 32px rgba(57,255,135,0.12), 0 0 0 1px rgba(57,255,135,0.15) !important;
      transform: translateY(-1px) !important;
    }
    .pgbadge-dot {
      width: 6px !important;
      height: 6px !important;
      border-radius: 50% !important;
      background: #39FF87 !important;
      flex-shrink: 0 !important;
      display: block !important;
      animation: pgpulse 2s ease-in-out infinite !important;
    }
    .pgbadge-label {
      color: rgba(250,250,250,0.5) !important;
      font-weight: 500 !important;
      font-size: 0.78rem !important;
    }
    .pgbadge-name {
      color: #39FF87 !important;
      font-weight: 600 !important;
      font-size: 0.78rem !important;
    }
    @keyframes pgpulse {
      0%, 100% { opacity: 1; transform: scale(1); }
      50% { opacity: 0.4; transform: scale(0.7); }
    }
  </style>

  <a href="https://growthos.com.br" target="_blank" rel="noopener" class="pgbadge">
    <span class="pgbadge-dot"></span>
    <span class="pgbadge-label">Built by</span>
    <span class="pgbadge-name">GrowthOS</span>
  </a>

  {{ footerExtra | safe if footerExtra }}
</body>
</html>
