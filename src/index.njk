<section class="section contato" id="contact">
  <div class="container">
    <div class="contato-inner">

      <div class="contato-info">
        <span class="section-label">Contact</span>
        <h2>Let's build your page</h2>
        <p>Tell us what you need. We'll get back to you within 2 hours with a plan and a price.</p>
        <ul class="contato-lista">
          <li>
            <span>✉️</span>
            <a href="mailto:{{ site.email }}">{{ site.email }}</a>
          </li>
          <li>
            <span>⏱️</span>
            <span>Landing pages delivered in 24 hours</span>
          </li>
          <li>
            <span>🌐</span>
            <span>Serving clients worldwide</span>
          </li>
          <li>
            <span>✅</span>
            <span>Free quote, zero commitment</span>
          </li>
        </ul>
      </div>

      <div class="contato-form">
        <form
          name="contact"
          method="POST"
          action="/thank-you/"
          data-netlify="true"
          data-netlify-honeypot="bot-field"
        >
          <input type="hidden" name="form-name" value="contact" />
          <div hidden aria-hidden="true" style="display:none!important;visibility:hidden;position:absolute;left:-9999px;">
            <label>Don't fill this out: <input name="bot-field" tabindex="-1" autocomplete="off" /></label>
          </div>

          <div class="form-row">
            <div class="form-group">
              <label for="name">Name *</label>
              <input type="text" id="name" name="name" required placeholder="Your name" />
            </div>
            <div class="form-group">
              <label for="email">Email *</label>
              <input type="email" id="email" name="email" required placeholder="you@email.com" />
            </div>
          </div>

          <div class="form-group">
            <label for="project_type">What do you need? *</label>
            <div class="select-wrapper">
              <select id="project_type" name="project_type" required>
                <option value="" disabled selected>Choose a service...</option>
                <option value="landing-page">Landing Page — live in 24 hours</option>
                <option value="full-website">Full Website — live in 7 days</option>
                <option value="maintenance">Monthly Maintenance — $50/month</option>
                <option value="analytics">Visitor Tracking Setup</option>
                <option value="other">Something else — describe below</option>
              </select>
            </div>
          </div>

          <div class="form-group">
            <label for="message">Tell us about your project</label>
            <textarea id="message" name="message" rows="4" placeholder="What's the goal of the page? Who is your audience? Any deadline we should know about?"></textarea>
          </div>

          <button type="submit" class="btn btn-primary btn--lg btn--full">
            Send request →
          </button>
        </form>
      </div>

    </div>
  </div>
</section>
